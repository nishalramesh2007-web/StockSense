// ─────────────────────────────────────────────
//  Data Models
// ─────────────────────────────────────────────

struct Supplier {
    int id;
    std::string name;
    std::string contact;
    std::string email;
};

struct Product {
    int id;
    std::string name;
    std::string category;
    int quantity;
    int low_stock_threshold;
    double price;
    int supplier_id;
    std::string sku;
    std::string last_updated;
};

// ─────────────────────────────────────────────
//  In-Memory Store
// ─────────────────────────────────────────────

std::mutex store_mutex;
std::map<int, Product>  products;
std::map<int, Supplier> suppliers;
int next_product_id  = 1;
int next_supplier_id = 1;

std::string current_timestamp() {
    time_t now = time(nullptr);
    char buf[20];
    strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", localtime(&now));
    return std::string(buf);
}

// ─────────────────────────────────────────────
//  JSON helpers  (no external lib)
// ─────────────────────────────────────────────

std::string escape_json(const std::string& s) {
    std::string out;
    for (char c : s) {
        if      (c == '"')  out += "\\\"";
        else if (c == '\\') out += "\\\\";
        else if (c == '\n') out += "\\n";
        else if (c == '\r') out += "\\r";
        else if (c == '\t') out += "\\t";
        else                out += c;
    }
    return out;
}

std::string supplier_to_json(const Supplier& s) {
    return "{\"id\":" + std::to_string(s.id) +
           ",\"name\":\"" + escape_json(s.name) + "\"" +
           ",\"contact\":\"" + escape_json(s.contact) + "\"" +
           ",\"email\":\"" + escape_json(s.email) + "\"}";
}

std::string product_to_json(const Product& p) {
    return "{\"id\":" + std::to_string(p.id) +
           ",\"name\":\"" + escape_json(p.name) + "\"" +
           ",\"category\":\"" + escape_json(p.category) + "\"" +
           ",\"quantity\":" + std::to_string(p.quantity) +
           ",\"low_stock_threshold\":" + std::to_string(p.low_stock_threshold) +
           ",\"price\":" + std::to_string(p.price) +
           ",\"supplier_id\":" + std::to_string(p.supplier_id) +
           ",\"sku\":\"" + escape_json(p.sku) + "\"" +
           ",\"last_updated\":\"" + escape_json(p.last_updated) + "\"" +
           ",\"low_stock\":" + (p.quantity <= p.low_stock_threshold ? "true" : "false") +
           "}";
}

// Tiny JSON field extractor
std::string json_get(const std::string& json, const std::string& key) {
    std::string search = "\"" + key + "\":";
    auto pos = json.find(search);
    if (pos == std::string::npos) return "";
    pos += search.size();
    while (pos < json.size() && json[pos] == ' ') pos++;
    if (json[pos] == '"') {
        pos++;
        std::string val;
        while (pos < json.size() && json[pos] != '"') {
            if (json[pos] == '\\' && pos + 1 < json.size()) { pos++; }
            val += json[pos++];
        }
        return val;
    } else {
        std::string val;
        while (pos < json.size() && json[pos] != ',' && json[pos] != '}') {
            val += json[pos++];
        }
        return val;
    }
}

